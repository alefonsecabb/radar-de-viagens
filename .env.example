# Travelpayouts (Aviasales) API — https://www.travelpayouts.com/developers/api
# Cadastro: travelpayouts.com → "Sign up" → confirmar e-mail → Developers → API Token
# (A mesma variável serve para Kiwi se conseguir acesso no futuro)
KIWI_API_KEY=your_travelpayouts_token

# Gmail — use uma "Senha de App" (não a senha normal da conta)
# Gere em: Conta Google > Segurança > Verificação em duas etapas > Senhas de app
GMAIL_USER=alefonsecabb@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password

# Destinatário do e-mail diário
RECIPIENT_EMAIL=alefonsecabb@gmail.com

# Ambiente: "local" ou "github_actions"
RUN_ENV=local
